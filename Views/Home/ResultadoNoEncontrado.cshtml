@{
    ViewData["Title"] = "Resultado";
    Layout = "_Layout";
}

<div class="public-bg public-bg-page"></div>

<div class="d-flex justify-content-center align-items-center result-page-shell">
    <div class="card shadow-lg p-5 border-0 rounded-4 text-center result-card">
        
        <div class="mb-4 mx-auto result-icon-shell">
            <img src="~/images/invalido.png" 
                alt="Cuenta no activada" 
                class="result-invalid-icon mb-4 mx-auto d-block">
        </div>

        <h2 class="fw-bold mb-5">¡Lo sentimos!</h2>
        @if (ViewBag.Exists == true)
        {
            <p class="text-muted mb-4">Su cuenta no está verificada</p>
        }
        else
        {
            <p class="text-muted mb-4">Su cuenta no existe</p>
        }
        <a href="/Home/ActivacionCuenta" class="btn btn-primary w-100 py-2">Volver</a>
    </div>
</div>