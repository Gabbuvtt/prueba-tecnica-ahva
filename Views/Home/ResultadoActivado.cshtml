@{
    ViewData["Title"] = "Resultado";
    Layout = "_Layout";
}
@model PruebaTecnicaAhva.Models.Auth.ActivationResultViewModel
<div class="public-bg public-bg-page"></div>

<div class="d-flex justify-content-center align-items-center result-page-shell">
    <div class="card shadow-lg p-5 border-0 rounded-4 text-center result-card">
        
        <div class="mb-4 mx-auto result-icon-shell">
            
            <img src="~/images/fondo_cohete.png" 
                class="result-icon-layer result-icon-bg"
                alt="Fondo cohete">
            
            <img src="~/images/cohete.png" 
                class="result-icon-layer result-icon-main"
                alt="Cohete">
                
        </div>

        <h2 class="fw-bold mb-5">¡@Model.Greeting, @Model.Nombres!</h2>
        <p class="text-muted mb-4">Su cuenta en el aplicativo X está activada. Ya puede iniciar sesión.</p>
        <a href="/Home/IniciarSesion" class="btn btn-primary w-100 py-2">Iniciar sesión</a>
    </div>
</div>