@{
    Layout = "_Layout";
    ViewData["UseDashboardShell"] = true;
}

<div style="height:100vh; width:100vw; overflow:hidden; display:flex; justify-content:center; align-items:flex-start; padding:0; margin:0; box-sizing:border-box; background-color:#E7E7E7;">
    <div style="width:100%; height:100%; background:#FFFFFF; border:none; display:flex; overflow:hidden;">
        <nav id="sidebarNav" style="width:76px; min-width:76px; height:100vh; background:#F9F9F9; border-right:1px solid #E8E8E8; z-index:1050; transition: all 0.3s ease;">
            <partial name="Components/Common/_SidebarMenu" />
        </nav>

        <div style="flex:1; display:flex; flex-direction:column; min-width:0; height:100%; overflow:hidden; background:#F4F5F7;">
            <header style="height:50px; min-height:50px; border-bottom:1px solid #8E1418; background:#AF151B;">
                <partial name="Components/Common/_HeaderAdmin" />
            </header>

            <main style="flex:1; overflow-y:auto; overflow-x:hidden; padding:14px 16px 0 16px;">
                @RenderBody()
            </main>

            <footer style="min-height:60px; border-top:1px solid #E5E7EB; background:#FFFFFF; display:flex; align-items:center; justify-content:flex-start; padding:8px 16px;">
                @if (IsSectionDefined("FooterContent"))
                {
                    @RenderSection("FooterContent", required: false)
                }
                else
                {
                    <partial name="Components/Common/_FooterLogos" />
                }
            </footer>
        </div>
    </div>
</div>

<div id="customTimeoutBackdrop" style="display:none; position:fixed; top:0; left:0; width:100vw; height:100vh; background:rgba(0,0,0,0.4); z-index:9998;"></div>
<div id="customTimeoutPopup" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); background:#F9FAFB; border:1px solid #E5E7EB; border-radius:8px; box-shadow:0 10px 25px rgba(0,0,0,0.1); width:480px; z-index:9999; padding:20px;">
    <div style="display:flex; align-items:flex-start; gap:16px;">
        <div style="background:#FEF3C7; border-radius:50%; width:40px; height:40px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
        </div>
        <div style="flex:1;">
            <h4 style="margin:0 0 8px 0; font-size:16px; color:#111827; font-weight:700;">Su sesión esta a punto de expirar</h4>
            <p style="margin:0 0 16px 0; font-size:13px; color:#4B5563; line-height:1.4;">Por seguridad, su sesión expirará en <span id="timeoutSeconds" style="font-weight:600;">50</span> segundos. Para continuar, seleccione "Extender sesión"</p>
            <div style="display:flex; justify-content:flex-end;">
                <button type="button" onclick="extendSession()" style="background:#D97706; color:#FFFFFF; border:none; border-radius:4px; padding:6px 14px; font-size:13px; font-weight:600; cursor:pointer; box-shadow:0 1px 2px rgba(0,0,0,0.05);">Extender sesión</button>
            </div>
        </div>
    </div>
</div>

<style>
    .sidebar-closed {
        width: 0px !important;
        min-width: 0px !important;
        overflow: hidden !important;
        border-right: none !important;
    }
    .sidebar-closed #sidebarToggleBtn {
        position: fixed !important;
        left: 10px;
        top: 60px;
        width: 40px !important;
        background: #F9F9F9;
        z-index: 2000;
        border-radius: 8px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }
    .sidebar-closed .sidebar-icon-link {
        display: none !important;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        let timeoutTimer;
        let countdownTimer;
        const timeoutDuration = 2 * 60 * 1000; // 2 minutes
        const warningDuration = 30 * 1000; // 30 seconds
        
        function resetTimer() {
            clearTimeout(timeoutTimer);
            clearInterval(countdownTimer);
            
            var popup = document.getElementById('customTimeoutPopup');
            var backdrop = document.getElementById('customTimeoutBackdrop');
            if (popup) popup.style.display = 'none';
            if (backdrop) backdrop.style.display = 'none';
            
            timeoutTimer = setTimeout(showWarning, timeoutDuration - warningDuration);
        }

        function showWarning() {
            var popup = document.getElementById('customTimeoutPopup');
            var backdrop = document.getElementById('customTimeoutBackdrop');
            if (popup) popup.style.display = 'block';
            if (backdrop) backdrop.style.display = 'block';
            
            let secondsLeft = warningDuration / 1000;
            document.getElementById('timeoutSeconds').innerText = secondsLeft;
            
            countdownTimer = setInterval(() => {
                secondsLeft--;
                document.getElementById('timeoutSeconds').innerText = secondsLeft;
                if (secondsLeft <= 0) {
                    clearInterval(countdownTimer);
                    window.location.href = '@Url.Action("Logout", "Home", new { timeout = true })';
                }
            }, 1000);
        }

        window.extendSession = function() {
            resetTimer();
            fetch('@Url.Action("Privacy", "Home")');
        }

        resetTimer();
    });

    function toggleSidebar() {
        var sidebar = document.getElementById('sidebarNav');
        if (sidebar) {
            sidebar.classList.toggle('sidebar-closed');
        }
    }
</script>

@await RenderSectionAsync("Scripts", required: false)