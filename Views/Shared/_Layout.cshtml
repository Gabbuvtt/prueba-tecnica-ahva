<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PruebaTecnicaAhva</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
@{
    var isDashboardLayout = ViewData["UseDashboardShell"] as bool? ?? false;
}
<body style="height: 100%; margin: 0; padding: 0; overflow: hidden;">

    @if (isDashboardLayout)
    {
        <div style="height:100vh; width:100%; background-color:#E7E7E7; overflow:hidden;">
            @RenderBody()
        </div>
    }
    else
    {
        <div style="display:flex; flex-direction:column; height:100vh; background-color:#E5E5E5;">
            <header>
                @await Html.PartialAsync("Components/Common/_NavbarAdmin")
            </header>

            <main style="flex:1; display:flex; align-items:center; justify-content:center; overflow:hidden; position:relative; background-color:#E5E5E5;">
                <div style="position:relative; z-index:1; width:100%;">
                    @RenderBody()
                </div>
            </main>

            <footer style="flex-shrink:0; min-height:60px; border-top:1px solid #E5E7EB; background:#FFFFFF; padding:8px 0;">
                <div style="width:100%; display:flex; justify-content:flex-end; align-items:center; padding-right:20px; box-sizing:border-box;">
                    @await Html.PartialAsync("Components/Common/_FooterLogos")
                </div>
            </footer>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>