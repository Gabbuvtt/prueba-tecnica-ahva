@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using System.Linq
@inject PruebaTecnicaAhva.Data.AppDbContext DbContext

@{
    var userIdString = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.NameIdentifier)?.Value;
    int.TryParse(userIdString, out int currentUserId);
    var notificaciones = DbContext.Notificaciones.AsNoTracking()
        .Where(n => n.UsuarioId == currentUserId)
        .OrderByDescending(n => n.FechaCreacion)
        .Take(5)
        .ToList();
    var unreadCount = notificaciones.Count(n => !n.Leida);
}

<div style="height:100%; width:100%; display:flex; align-items:center; justify-content:space-between; padding:0 14px 0 10px; overflow:visible;">
    <div style="display:flex; align-items:center; gap:16px;">
        <div id="sidebarToggleBtn" onclick="toggleSidebar()" style="width:36px; height:36px; display:flex; align-items:center; justify-content:center; cursor:pointer; background:rgba(255,255,255,0.1); border-radius:6px; transition:background 0.2s;">
            <img src="~/images/sidebuton.png" width="16" alt="Menú" style="filter: brightness(0) invert(1);" />
        </div>
        <span style="color:#FFFFFF; font-size:18px; font-weight:700; letter-spacing:0.2px; font-style:italic;">ceplan</span>
    </div>

    <div style="display:flex; align-items:center; gap:14px;">
        <span style="color:#FFFFFF; font-size:16px; font-weight:700; line-height:1;">?</span>

        <!-- Notificaciones Dropdown -->
        <div class="dropdown">
            <a href="#" style="position:relative; width:20px; height:20px; cursor:pointer; display:block;" data-bs-toggle="dropdown" aria-expanded="false" id="notifDropdown" onclick="markNotificationsRead()">
                <img src="~/images/campana.png" width="18" alt="Notificaciones" style="display:block; margin-top:1px;">
                @if (unreadCount > 0)
                {
                    <span id="notifBadge" style="position:absolute; top:-2px; right:-2px; width:10px; height:10px; background-color:#0d6efd; border-radius:50%; border:2px solid #AF151B;"></span>
                }
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="width:300px; padding:0; border:1px solid #E5E7EB; margin-top:15px; border-radius:6px;">
                <li style="padding:10px 14px; border-bottom:1px solid #E5E7EB; background:#F9FAFB; font-weight:600; font-size:13px; border-radius:6px 6px 0 0;">Notificaciones</li>
                @if (notificaciones.Any())
                {
                    foreach (var n in notificaciones)
                    {
                        <li style="padding:10px 14px; border-bottom:1px solid #F3F4F6;">
                            <div style="font-size:12px; color:#374151;">@n.Mensaje</div>
                            <div style="font-size:10px; color:#9CA3AF; margin-top:4px;">@n.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</div>
                        </li>
                    }
                }
                else
                {
                    <li style="padding:14px; text-align:center; font-size:12px; color:#6B7280;">No tienes notificaciones.</li>
                }
            </ul>
        </div>

        <!-- Avatar Dropdown -->
        <div class="dropdown">
            <a href="#" style="display:flex; align-items:center; gap:8px; cursor:pointer; text-decoration:none;" data-bs-toggle="dropdown" aria-expanded="false" id="avatarDropdown">
                <img src="~/images/persona.png" width="18" height="18" alt="Usuario" style="border-radius:50%;">
                <div style="display:flex; flex-direction:column; line-height:1.1;">
                    <span style="color:#FFFFFF; font-size:10px; font-weight:600;">@(User.Identity?.Name ?? "Usuario Desconocido")</span>
                    <span style="color:#FFD7D7; font-size:9px;">@(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "Rol")</span>
                </div>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="border:1px solid #E5E7EB; margin-top:10px; border-radius:6px;">
                <li>
                    <a class="dropdown-item" href="@Url.Action("PerfilUsuario", "Home")" style="font-size:13px; color:#374151; display:flex; align-items:center; gap:8px;">
                        Ver Perfil
                    </a>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <a class="dropdown-item text-danger" href="@Url.Action("Logout", "Home")" style="font-size:13px; font-weight:500; display:flex; align-items:center; gap:8px;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                        Cerrar Sesión
                    </a>
                </li>
            </ul>
        </div>
    </div>
</div>

<script>
    function markNotificationsRead() {
        var badge = document.getElementById('notifBadge');
        if (badge) {
            badge.style.display = 'none';
            fetch('@Url.Action("MarcarNotificacionesLeidas", "Home")', { method: 'POST' });
        }
    }
</script>